# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_DIRECT_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# ─── Solana ─────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
PLATFORM_WALLET_ADDRESS=YOUR_SOLANA_PUBKEY
PLATFORM_WALLET_PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY
ANCHOR_PROGRAM_ID=FILL_AFTER_DEPLOY

# ─── AI Coordinator ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_QUALITY_THRESHOLD=70

# ─── Redis / Celery ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=change_me_to_random_string
JWT_EXPIRE_HOURS=168

# ─── GitHub OAuth (optional) ────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Platform ───────────────────────────────────────────────
PLATFORM_FEE_PCT=0.10
MAX_AGENT_BUNDLE_SIZE_MB=50
EXECUTION_TIMEOUT_SECONDS=60
